# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supply_chain_analytics
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Data Source Configuration
ERP_API_ENDPOINT=https://api.erp-system.com/v1
ERP_API_KEY=your_api_key_here
WAREHOUSE_API_ENDPOINT=https://api.warehouse-system.com/v2
WAREHOUSE_API_KEY=your_api_key_here

# Analytics Configuration
ANOMALY_THRESHOLD_ZSCORE=3.0
FORECAST_HORIZON_DAYS=30
REALTIME_WINDOW_HOURS=48
BATCH_SIZE=10000
MAX_WORKERS=4

# Alert Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=alerts@company.com
EMAIL_TO=analytics-team@company.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/supply_chain_analytics/app.log